# Backend API (must include /api — matches Express app.use("/api", routes))
# Local backend — must include /api (routes are mounted at app.use("/api", ...))
VITE_API_BASE_URL=http://127.0.0.1:2002/api

# Render production (either form works; /api is appended automatically if missing):
# VITE_API_BASE_URL=https://ai-fitness-backend-1-hdhl.onrender.com/api
# VITE_API_BASE_URL=https://ai-fitness-backend-1-hdhl.onrender.com

# Google OAuth — same Client ID as backend GOOGLE_CLIENT_ID (Web application type)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
